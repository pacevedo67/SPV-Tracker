# ── Server ──────────────────────────────────────────────
PORT=3030
NODE_ENV=development

# Full URL of your deployment (no trailing slash)
# Render sets this automatically if you use render.yaml,
# but you still need to set it manually in the Render dashboard.
BASE_URL=http://localhost:3030

# ── Security ─────────────────────────────────────────────
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me-to-a-random-string

# ── Database ─────────────────────────────────────────────
# Leave unset for local dev (uses ./questionnaire.db).
# On Render with a persistent disk mounted at /data, set to:
# DATABASE_PATH=/data/questionnaire.db
# DATABASE_PATH=

# ── Email via Resend (https://resend.com) ─────────────────
# 1. Sign up at resend.com
# 2. Add & verify your sending domain under Domains
# 3. Create an API key under API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Must match a verified domain in your Resend account
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=SPV Tracker
